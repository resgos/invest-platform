# ============================================================
#  Группа Титан — production .env
#  Скопировать в /home/deploy/gruppa-titan/.env и заполнить
# ============================================================

# 64-символьная случайная строка. Для генерации:
#   python3 -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=REPLACE_WITH_RANDOM_HEX

# SQLite — абсолютный путь (4 слэша), файл лежит в instance/, бэкапится в backups/
DATABASE_URI=sqlite:////home/deploy/gruppa-titan/instance/invest.db

# Админ создаётся автоматически при первом старте
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ReplaceWithStrongPassword123!
ADMIN_EMAIL=admin@gruppa-titan.ru

# Сколько неудачных попыток до блокировки аккаунта
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Telegram-бот (получите токен у @BotFather, chat_id — у вашей группы)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Прокси для Telegram API (РФ блокирует прямой доступ).
# Форматы:
#   http://user:pass@host:port
#   socks5://user:pass@host:port  (требует pip install pysocks)
TELEGRAM_PROXY=

# Rate limiter: redis://localhost:6379/0 — для multi-worker prod (по умолчанию)
# memory:// — для тестов на одном worker
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0

# Установите true когда поднимете HTTPS
SESSION_COOKIE_SECURE=false

# Деплой-папка (используется в инструкциях бэкапа)
DEPLOY_DIR=gruppa-titan
